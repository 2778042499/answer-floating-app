# Force LF line endings for shell scripts and batch files
* text=auto
*.sh text eol=lf
*.bat text eol=crlf
*.gradle text eol=lf
*.gradle.kts text eol=lf
*.properties text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.xml text eol=lf
*.java text eol=lf
*.kt text eol=lf
*.kts text eol=lf
*.md text eol=lf
*.json text eol=lf
*.gitignore text eol=lf
